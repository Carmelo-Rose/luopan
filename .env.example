# 浏览器 user-data 目录（复用已登录的 Chrome/Chromium profile）
BROWSER_USER_DATA_DIR=C:\Users\YourName\AppData\Local\Google\Chrome\User Data
BROWSER_CHANNEL=chrome

# 抖音罗盘短视频榜入口与接口关键字
COMPASS_URL=https://compass.jinritemai.com/
RANK_ENTRY_URL=https://compass.jinritemai.com/shop/chance/merchandise-product-rank?rank_type=3
RANK_API_PATH=video_bring_good
RANK_TAB_TEXT=短视频榜

# SQLite 数据库路径
DB_PATH=./data/compass.db

# 推送渠道：wecom | lark | none
NOTIFY_CHANNEL=wecom

# 企微 Webhook（大盘 --multi 摘要推送）
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
# 服配 --acc 独立群机器人；留空则回退到上面的 WECOM_WEBHOOK_URL
WECOM_ACC_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_ACC_KEY

# 飞书 Webhook（备用通知）
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN

# 飞书多维表格同步（配齐下面两项即启用，每轮把异动写入该 Base 表）
# 经本机 lark-cli 子进程写入，需先 lark-cli auth login 登录。身份默认 user。
LARK_BASE_APP_TOKEN=
LARK_TABLE_ID=
LARK_AS=user

# 服配叶子类目支线专属飞书表（复用 LARK_BASE_APP_TOKEN / LARK_AS）
# 在现有 Base App 内新建「服配」表，字段名与大盘表一致（含 价格/支付金额/商品图），填入新表 id
# 运行：python run.py --acc [--dry-run] [--mock]
# 注意：短视频榜 API 只接受 L2 category_id，服配支线会采集「服饰内衣 > 服装」
# TOP200 后按返回的 leaf_category_id 本地拆分。
LARK_ACC_TABLE_ID=

# 服配支线：类目树路径（逗号分隔，从 L1 到目标父节点）及要监控的叶子类目名
# 默认值内置在 config/settings.py，按需覆盖
# ACC_PATH=服饰内衣,服装,服装配饰
# ACC_LEAF_NAMES=帽子,丝巾/披肩/头巾,面罩,防晒口罩,防晒袖套/冰袖

# ── 企微智能表格同步（企业自建应用凭证，非 Webhook 群机器人）─────────
# corpid：企业微信管理后台 → 我的企业 → 企业信息 → 企业ID（ww 开头）
# corpsecret：应用管理 → 自建应用 → 查看 Secret
# docid：智能表格文档 ID（从 URL 或文档权限页面获取）
# sheet_id：子表 ID（从 URL 参数 tab= 或权限页面获取）
# 配齐 4 项即自动启用，每轮把异动写入该智能表格
WECOM_CORPID=
WECOM_CORPSECRET=
WECOM_SMARTSHEET_DOCID=
WECOM_SMARTSHEET_SHEET_ID=

# 每页条数（固定 10，用于校验）
PAGE_SIZE=10
# 总页数
TOTAL_PAGES=20

# 固定行业类目（单 scope 兼容入口；V2 主流程优先使用 --multi / --acc）
INDUSTRY_ID=7
CATEGORY_ID=1000002719
CATEGORY_NAME=智能家居/五金/工具/全部

# 多类目模式目标一级类目：* 表示账号可见的全部一级类目；也可填写逗号分隔名单
TARGET_L1_CATEGORIES=智能家居,玩具乐器,钟表配饰,图书教育,服饰内衣,个护家清,运动户外
